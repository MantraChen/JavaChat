# Maven Wrapper: 使用项目内 .mvn/wrapper 中的 jar，无需本机安装 Maven

if [ -z "$JAVA_HOME" ]; then
  if [ -x "/usr/libexec/java_home" ]; then
    JAVA_HOME="$(/usr/libexec/java_home 2>/dev/null)" && export JAVA_HOME
  fi
  if [ -z "$JAVA_HOME" ]; then
    # Homebrew OpenJDK 常见路径（Apple Silicon / Intel）
    if [ -x "/opt/homebrew/opt/openjdk@17/bin/java" ]; then
      export JAVA_HOME="/opt/homebrew/opt/openjdk@17"
    elif [ -x "/opt/homebrew/opt/openjdk/bin/java" ]; then
      export JAVA_HOME="/opt/homebrew/opt/openjdk"
    elif [ -x "/usr/local/opt/openjdk@17/bin/java" ]; then
      export JAVA_HOME="/usr/local/opt/openjdk@17"
    fi
  fi
fi

if [ -z "$JAVACMD" ]; then
  if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
  else
    JAVACMD="$(command -v java 2>/dev/null)"
  fi
fi

if [ ! -x "$JAVACMD" ]; then
  echo "Error: Java not found. Install JDK 17 (e.g. brew install openjdk@17) or set JAVA_HOME." >&2
  exit 1
fi

# 查找项目根目录（含 .mvn 的目录）
basedir="$(cd "$(dirname "$0")" && pwd)"
while [ "$basedir" != "/" ]; do
  if [ -d "$basedir/.mvn" ]; then
    break
  fi
  basedir="$(dirname "$basedir")"
done

MAVEN_PROJECTBASEDIR="$basedir"
export MAVEN_PROJECTBASEDIR

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ ! -r "$WRAPPER_JAR" ]; then
  echo "Error: $WRAPPER_JAR not found. Run this script from chat-server directory." >&2
  exit 1
fi

exec "$JAVACMD" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
